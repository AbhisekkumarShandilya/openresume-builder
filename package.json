{
  "name": "openresume-builder",
  "version": "1.0.0",
  "description": "OpenResume Builder — open-source cross-platform resume builder",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development node scripts/launch-electron.cjs\"",
    "build": "vite build",
    "start": "npm run build && node scripts/launch-electron.cjs",
    "dist": "vite build && electron-builder"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.abhisekkumarshandilya.openresumebuilder",
    "productName": "OpenResume Builder",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "AbhisekkumarShandilya",
      "repo": "openresume-builder"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
